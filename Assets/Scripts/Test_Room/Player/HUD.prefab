--- !u!114 &5231424676741012431
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2049424538277915923}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2c65fd54c0297ab45a3a4dc0519e33e3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogManager: {fileID: 1522249548704971655}
  merchantManager: {fileID: 0}
  inventoryManager: {fileID: 0}
  playerHealth: {fileID: 0}
  optionsPanel: {fileID: 316306556274045694}
  acceptButton: {fileID: 63737860863256847}
  backButton: {fileID: 7940734855780671619}
  converseButton: {fileID: 0}
  firstVisitLines:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"Ah, otra alma perdida que cae en mis dominios. \xBFBuscas alivio o una
      deuda?\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  routineLines:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"Mis mercanc\xEDas son \xFAnicas y mi tiempo es oro, o lo que quede de
      ti. \xBFNecesitas algo o solo vas a mirar?\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"En este lugar, la \xFAnica moneda real es la necesidad. No la desperdicies
      con preguntas triviales.\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: '"Todo tiene un precio. La vida, la muerte, el silencio... y por supuesto,
      mis servicios."'
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  pactOfferLines:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"Veo la marca de la agon\xEDa sobre ti. Un peque\xF1o sacrificio a cambio
      de una gran ventaja. \xBFAceptas el precio que el Inframundo exige?\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  tooHealthyLines:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"Vienes a m\xED con las venas llenas de vida. No tengo nada que ofrecerte,
      y t\xFA nada que perder. Vuelve cuando te acerques al borde.\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  friendlyLines:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"La oscuridad te sienta bien, viajero. Sigue aumentando tu deuda conmigo
      y te mostrar\xE9 secretos que la luz nunca conoci\xF3.\""
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"Tus enemigos tienen grietas en sus defensas. Yo lo s\xE9. \xBFTe ayudo
      a explotarlas? Por un precio, claro.\""
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"Me agradas. La avaricia es un buen motor. T\xF3malo de un experto: los
      mejores tratos se hacen en silencio.\""
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  hostileLines:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"\xBFPor qu\xE9 pierdes el tiempo? Cada segundo que me haces esperar
      cuesta algo m\xE1s que oro.\""
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"Me aburres. Tu conversaci\xF3n es tan ins\xEDpida como tu alma. Vuelve
      cuando tengas algo interesante que ofrecer, o vete.\""
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: "\"No olvides qui\xE9n te permite seguir respirando en mi sala. No abuses
      de mi... indulgencia.\""
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  blockedLine:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: '"Has agotado mi paciencia. Mis favores son para almas desesperadas, no
      para parlanchines. Vete, antes de que te cobre por el tiempo perdido."'
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  pactAcceptLines:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: 8
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  pactShowDetailsLines:
  - CharacterName: Mercader
    ProfileImage: {fileID: 0}
    Text: 9
    WaitForInput: 0
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  maxReputationRewardLines: []
  pactVoiceClip: {fileID: 8300000, guid: 74a1d3a7afa680241b89bac49426b703, type: 3}
  pactVoicePitch: 1
  pactVoiceFrequency: 2
  OnDialogCompleteEvent:
    m_PersistentCalls:
      m_Calls: []
