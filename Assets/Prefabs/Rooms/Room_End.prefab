--- !u!114 &2819772441107752507
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2155585864286849737}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f890943e6f85d6e4a88975ac1322103f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  Sala1_IntroDialog:
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\"\xA1Y aqu\xED estamos, damas y demonios! Nuestro querido concursante
      ha sobrevivido hasta el punto donde el mism\xEDsimo suelo se cansa de ser pisado.\"\r\n"
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\"Dicen que el peso de la existencia aplasta a cualquiera, \xA1pero yo
      prefiero que lo haga algo mucho m\xE1s... literal!\"\r\n"
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\"\xBFPodr\xE1 nuestro peque\xF1o saco de arena soportar la presi\xF3n
      estelar de este escenario? \xA1No cambien de canal!\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  onFinishDialog:
    m_PersistentCalls:
      m_Calls: []
