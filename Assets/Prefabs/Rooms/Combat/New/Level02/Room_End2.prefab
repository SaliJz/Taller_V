--- !u!114 &8998544851395009581
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4728521640344073078}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f890943e6f85d6e4a88975ac1322103f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  Sala1_IntroDialog:
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\"\xA1Si la basura emocional les pareci\xF3 un espect\xE1culo tr\xE1gico,
      esperen a ver lo que nos aguarda detr\xE1s del tel\xF3n!\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\"Algunos se esfuerzan tanto en juntar sus pedazos rotos para armarse
      una armadura brillante... pat\xE9tico, \xBFno lo creen?\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\"\xA1Y justo hacia all\xE1 va nuestro protagonista! Aunque pens\xE1ndolo
      bien, t\xFA encajar\xEDas perfectamente en ese basurero de ilusiones... \xA1Qu\xE9
      comience el segundo acto!\""
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  onFinishDialog:
    m_PersistentCalls:
      m_Calls: []
