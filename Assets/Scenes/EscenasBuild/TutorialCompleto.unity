  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f890943e6f85d6e4a88975ac1322103f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  Sala1_IntroDialog:
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\xA1Y ah\xED est\xE1! De la nada. Literalmente. Para que este show no
      sea aburrido, te hice esa cosa (tu escudo) para que puedas moverte. T\xF3malo
      como la \xFAnica cortes\xEDa que tendr\xE1s de m\xED :)"
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "Por cierto, \xBFves ese brillo dorado? Gr\xE1batelo. Esa luz te indicar\xE1
      la ruta principal o los caminos que puedes tomar en cualquier nivel."
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  onFinishDialog:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 953363980}
        m_TargetAssemblyTypeName: TutorialHUDAnimator, Assembly-CSharp
        m_MethodName: SetAndShowInstruction
        m_Mode: 5
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: Para moverte, usa !MOVE    y sigue el camino.
          m_BoolArgument: 0
        m_CallState: 2
      - m_Target: {fileID: 1821268767}
        m_TargetAssemblyTypeName: PlayerStatsManager, Assembly-CSharp
        m_MethodName: ResetRunStatsToDefaults
        m_Mode: 1
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: Para moverte, usa !MOVE    y sigue el camino.
          m_BoolArgument: 0
        m_CallState: 2
