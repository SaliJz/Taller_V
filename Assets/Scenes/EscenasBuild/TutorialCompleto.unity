--- !u!114 &957942374
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 957942372}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8950cecb37c22ae45b34769c87bead27, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  slimeArmor: {fileID: 1911408829}
  playerAbilityScript: {fileID: 1821268776}
  specialObjectToActivate: {fileID: 1051880186}
  activationDuration: 2
  requiredInitialHits: 3
  dialogue1_Intro:
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "Oh, este es terco. Tu escudito normal no servir\xE1. Sobrec\xE1rgalo para
      entrar en Modo Berserker y llamar su atenci\xF3n. Apl\xE1stalo\u2026 de cerquita."
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  dialogue2_Contract:
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "Magn\xEDfico. Envuelve tus golpes con tu aura demon\xEDaca. La superresistencia
      es vulnerable a ella."
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: Pero no te relajes. Solo tienes cinco segundos por contrato,  antes de
      que empieces a consumir tu propia esencia vital.
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "Vamos. Recuerda todo de una vez y convi\xE9rtete en uno de mis guerreros,
      Aldous."
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  dialogue3_DiabloLaugh:
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\u201C\xA1Mujajajajaja!\u201D\r"
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  dialogue4_Success:
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "Buen chico. Sigamos con el pr\xF3ximo acto de esta tortura, que el tiempo
      (tu tiempo) es oro."
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  dialogue_OnPlayerDamaged:
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "\xA1Uuuy, mira c\xF3mo te desmoronas! El poder no es gratis, amiguito.
      Tu energ\xEDa se acab\xF3 y ahora te est\xE1s comiendo tu propio tiempo de
      vida."
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  - CharacterName: DIABLO
    ProfileImage: {fileID: 0}
    Text: "Apaga el escudo con el mismo bot\xF3n que lo encendiste, a menos que quieras
      morir en el tutorial. :p"
    WaitForInput: 1
    AutoAdvanceDelay: 0
    VoiceClip: {fileID: 8300000, guid: 8d968318300e23d419dcb07531cf69a3, type: 3}
    VoicePitch: 1
    VoiceFrequency: 2
  OnDisplaySkillReminder:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 953363980}
        m_TargetAssemblyTypeName: TutorialHUDAnimator, Assembly-CSharp
